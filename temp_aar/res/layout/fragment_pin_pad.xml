<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
   ><!--
    tools:context=".module.PinPad"-->
   <!-- <include layout="@layout/header_lyt"/>-->

    <LinearLayout
        android:id="@+id/title_amt_lyt"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:weightSum="2"
        android:orientation="horizontal"
        android:baselineAligned="false"
        android:background="@color/colorPrimary"
        android:visibility="visible">
        <RelativeLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="10dp"
            android:layout_weight="1"
            tools:ignore="NestedWeights">

            <TextView
                android:id="@+id/sale_type"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text=""
                android:textColor="@android:color/white"
                android:textSize="22sp" />
        </RelativeLayout>
        <RelativeLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="20dp"
            android:layout_weight="1">

            <TextView
                android:id="@+id/payment_type"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text=""
                android:textColor="@android:color/white"
                android:textSize="22sp" />
        </RelativeLayout>
    </LinearLayout>
    <LinearLayout
        android:id="@+id/pin_layout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2.5">
        <RelativeLayout
            android:layout_width="match_parent"
            android:gravity="center"
            android:layout_height="match_parent"
            tools:ignore="UselessParent">
            <TextView
                android:id="@+id/textViewPinType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentLeft="true"
                android:layout_alignParentStart="true"
                android:layout_alignParentTop="true"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:text=""
                android:textColor="@android:color/black"
                android:paddingBottom="10dp"
                android:textSize="20sp"
                tools:ignore="RtlHardcoded" />

            <TextView
                android:id="@+id/pin_input"
                android:layout_width="@dimen/one_hundred_fourty_five_dp"
                android:layout_height="@dimen/fourty_dp"
                android:layout_below="@+id/textViewPinType"
                android:layout_centerHorizontal="true"
                android:background="@drawable/pin_pad_edt_txt"
                android:focusable="false"
                android:focusableInTouchMode="false"
                android:gravity="center"
                android:inputType="numberPassword"
                android:maxLength="12"
                android:textColor="@color/white"
                android:textSize="20dp"
                tools:ignore="SpUsage,TextViewEdits" />
            <TextView
                android:id="@+id/textViewME_PAN"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentLeft="true"
                android:layout_alignParentStart="true"
                android:layout_marginTop="22dp"
                android:text="PAN : "
                android:textColor="@android:color/black"
                android:textSize="20sp"
                android:visibility="invisible"
                tools:ignore="HardcodedText,RtlHardcoded" />

            <TextView
                android:id="@+id/textViewME_EXP"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_above="@+id/textViewME_CSC"
                android:layout_alignParentLeft="true"
                android:layout_alignParentStart="true"
                android:text="EXP : "
                android:textColor="@android:color/black"
                android:textSize="20sp"
                android:visibility="invisible"
                tools:ignore="HardcodedText,RtlHardcoded" />

            <TextView
                android:id="@+id/textViewME_CSC"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentLeft="true"
                android:layout_alignParentStart="true"
                android:layout_marginBottom="11dp"
                android:text="CSC : "
                android:textColor="@android:color/black"
                android:textSize="20sp"
                android:visibility="invisible"
                tools:ignore="HardcodedText,RtlHardcoded" />
        </RelativeLayout>
    </LinearLayout>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:weightSum="10"
        android:orientation="vertical"
        android:layout_weight="7">
        <LinearLayout
            android:id="@+id/pinpad_lyt"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="10"
            android:visibility="visible"
            android:orientation="vertical"
            android:weightSum="10"
            tools:ignore="DisableBaselineAlignment,NestedWeights,UselessParent">


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginEnd="1dp"
                android:layout_marginStart="1dp"
                android:layout_weight="6">
                <TableLayout
                    android:id="@+id/keyboard"
                    android:layout_width="fill_parent"
                    android:layout_height="fill_parent"
                    android:orientation="vertical"
                    android:showDividers="middle"
                    android:weightSum="3">

                    <TableRow style="@style/keyboard_row">

                        <TextView
                            android:id="@+id/KBD1"
                            style="@style/keyboard_number_button"
                            android:text="1" />

                        <TextView
                            android:id="@+id/KBD2"
                            style="@style/keyboard_number_button"
                            android:text="2" />

                        <TextView
                            android:id="@+id/KBD3"
                            style="@style/keyboard_number_button"
                            android:text="3" />
                    </TableRow>

                    <TableRow
                        style="@style/keyboard_row">

                        <TextView
                            android:id="@+id/KBD4"
                            style="@style/keyboard_number_button"
                            android:text="4"/>

                        <TextView
                            android:id="@+id/KBD5"
                            style="@style/keyboard_number_button"
                            android:text="5" />

                        <TextView
                            android:id="@+id/KBD6"
                            style="@style/keyboard_number_button"
                            android:text="6" />
                    </TableRow>

                    <TableRow
                        style="@style/keyboard_row">
                        <TextView
                            android:id="@+id/KBD7"
                            style="@style/keyboard_number_button"
                            android:text="7" />

                        <TextView
                            android:id="@+id/KBD8"
                            style="@style/keyboard_number_button"
                            android:text="8" />

                        <TextView
                            android:id="@+id/KBD9"
                            style="@style/keyboard_number_button"
                            android:text="9" />
                    </TableRow>
                </TableLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="4"
                android:orientation="horizontal"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:layout_marginTop="1dp"
                android:layout_marginBottom="2dp"
                android:weightSum="3">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1">
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="1dp">

                        <TextView
                            android:id="@+id/KBD_Cancel"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/rounded_rect_red"
                            android:gravity="center"
                            android:text="X"
                            android:textColor="@android:color/black"
                            android:textSize="24sp"
                            tools:ignore="HardcodedText" />
                    </RelativeLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:weightSum="2"
                    android:layout_marginStart="1dp"
                    android:layout_marginEnd="1dp"
                    android:layout_weight="1">
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_marginBottom="1dp"
                        android:layout_weight="1"
                        tools:ignore="NestedWeights">

                        <TextView
                            android:id="@+id/KBD0"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/rounded_rectangle"
                            android:gravity="center"
                            android:text="0"
                            android:textColor="@color/white"
                            android:textSize="22dp"
                            tools:ignore="SpUsage" />
                    </RelativeLayout>
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:layout_marginTop="1dp">

                        <TextView
                            android:id="@+id/KBD_Clear"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/rounded_rect_yellow"
                            android:gravity="center"
                            android:inputType=""
                            android:text="C"
                            android:textSize="22dp"
                            tools:ignore="HardcodedText,SpUsage" />
                    </RelativeLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1">
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginStart="1dp">
                        <TextView
                            android:id="@+id/KBD_Enter"
                            android:background="@drawable/rounded_rect_green"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="Enter"
                            android:textColor="@android:color/black"
                            android:textSize="24sp"
                            tools:ignore="HardcodedText" />
                    </RelativeLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</LinearLayout>

